.container {
  min-height: 100vh;
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
}

.section-title {
  font-size: 18px;
  color: #a0a0b8;
  padding: 28rpx 8rpx 12rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
}

/* Vant Cell 图标样式调整 */
.van-cell__left-icon {
  font-size: 24px !important;
  margin-right: 16rpx;
}

.menu-hint {
  font-size: 18px;
  color: #a0a0b8;
}

.guardian-quota-hint {
  padding: 16rpx 32rpx 0;
  font-size: 14px;
  color: #a0a0b8;
  line-height: 1.6;
}

.tips {
  margin-top: 40rpx;
  background: linear-gradient(135deg, #fffcf0, #fff8e1);
  border: 1rpx solid rgba(240, 147, 43, 0.1);
}

.tips-title {
  font-size: 19px;
  font-weight: 700;
  color: #f0932b;
  margin-bottom: 20rpx;
}

.tips-text {
  font-size: 18px;
  color: #7a6e5a;
  line-height: 2.2;
}
