.container {
  min-height: 100vh;
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
}

/* ===== 日期头部 ===== */
.date-bar {
  background: linear-gradient(135deg, #4A90D9 0%, #5BA3EC 50%, #6BB5F0 100%);
  color: #ffffff;
  padding: 24rpx 36rpx 44rpx;
}

.date-bar-title {
  display: block;
  font-size: 56rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 4rpx;
  margin-bottom: 16rpx;
}

.date-bar-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.date-left {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
}

.date-text {
  font-size: 34px;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.weekday {
  font-size: 26px;
  opacity: 0.85;
  font-weight: 500;
}

.date-greeting {
  font-size: 36px;
}

/* ===== 成员 Tab ===== */
.member-tabs {
  white-space: nowrap;
  padding: 24rpx 24rpx 16rpx;
}

.tab {
  display: inline-block;
  padding: 20rpx 44rpx;
  margin-right: 16rpx;
  border-radius: 40rpx;
  font-size: 24px;
  color: #6b6b80;
  background: #ffffff;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  font-weight: 600;
  transition: all 0.2s ease;
}

.tab:active {
  transform: scale(0.95);
}

.tab-active {
  background: linear-gradient(135deg, #4A90D9, #5BA3EC);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(74, 144, 217, 0.3);
}

/* ===== 环形进度卡片 ===== */
.summary-card {
  margin-top: 16rpx;
  padding: 36rpx;
}

.summary-content {
  display: flex;
  align-items: center;
  gap: 36rpx;
}

.ring-progress {
  flex-shrink: 0;
}

.ring-outer {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: #f0f2f5;
  position: relative;
  overflow: hidden;
}

.ring-left-wrap {
  position: absolute;
  top: 0;
  left: 0;
  width: 50%;
  height: 100%;
  overflow: hidden;
}

.ring-left {
  position: absolute;
  top: 0;
  left: 0;
  width: 200%;
  height: 100%;
  border-radius: 50%;
  background: transparent;
  border: 16rpx solid #2ecc71;
  box-sizing: border-box;
  transform-origin: center center;
  transform: rotate(0deg);
  clip: rect(0, auto, auto, 50%);
}

.ring-right-wrap {
  position: absolute;
  top: 0;
  right: 0;
  width: 50%;
  height: 100%;
  overflow: hidden;
}

.ring-right {
  position: absolute;
  top: 0;
  right: 0;
  width: 200%;
  height: 100%;
  border-radius: 50%;
  background: transparent;
  border: 16rpx solid #2ecc71;
  box-sizing: border-box;
  transform-origin: center center;
  transform: rotate(0deg);
  clip: rect(0, 50%, auto, 0);
}

.ring-inner {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  right: 16rpx;
  bottom: 16rpx;
  border-radius: 50%;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ring-percent {
  font-size: 22px;
  font-weight: 700;
  color: #2ecc71;
}

.summary-info {
  flex: 1;
}

.summary-title {
  font-size: 26px;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 10rpx;
}

.summary-detail {
  font-size: 22px;
  color: #8c8ca1;
  margin-bottom: 20rpx;
}

.summary-bar {
  width: 100%;
}

.progress-bar {
  width: 100%;
  height: 18rpx;
  background: #f0f2f5;
  border-radius: 9rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #2ecc71, #27ae60);
  border-radius: 9rpx;
  transition: width 0.5s ease;
}

/* ===== 漏服提醒栏 ===== */
.alert-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: linear-gradient(135deg, #fff5f5 0%, #ffe8e8 100%);
  color: #e74c3c;
  padding: 28rpx 32rpx;
  font-size: 24px;
  font-weight: 700;
  margin: 16rpx 24rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(231, 76, 60, 0.15);
}

.alert-icon {
  font-size: 28px;
}

.alert-text {
  flex: 1;
}

/* ===== 药物卡片 ===== */
.med-list {
  padding: 0;
}

.med-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 0;
  margin-top: 16rpx;
  padding: 32rpx;
  transition: all 0.2s ease;
}

.med-card:active {
  transform: scale(0.98);
}

.med-card.missed {
  border-left: 8rpx solid #e74c3c;
  background: linear-gradient(90deg, #fff8f8, #ffffff);
}

.med-card.taken {
  opacity: 0.55;
}

.med-card-left {
  display: flex;
  align-items: center;
  flex: 1;
  gap: 24rpx;
}

.med-time-badge {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 110rpx;
}

.med-time-icon {
  font-size: 22px;
  margin-bottom: 6rpx;
}

.med-time {
  font-size: 28px;
  font-weight: 700;
  color: #4A90D9;
}

.med-info {
  flex: 1;
}

.med-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.med-name {
  font-size: 28px;
  font-weight: 700;
  color: #1a1a2e;
}

.med-sub-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 10rpx;
}

.med-member {
  font-size: 22px;
  color: #888;
  background: #f0f2f5;
  padding: 4rpx 20rpx;
  border-radius: 10rpx;
}

.med-dosage {
  font-size: 22px;
  color: #888;
}

.med-card-right {
  flex-shrink: 0;
  margin-left: 16rpx;
}

/* ===== 吃药按钮 ===== */
.btn-take {
  background: linear-gradient(135deg, #2ecc71, #27ae60);
  color: #ffffff;
  border: none;
  border-radius: 18rpx;
  padding: 20rpx 40rpx;
  font-size: 24px;
  font-weight: 700;
  min-width: 160rpx;
  line-height: 1.4;
  box-shadow: 0 6rpx 20rpx rgba(39, 174, 96, 0.3);
  transition: all 0.2s ease;
}

.btn-take:active {
  transform: scale(0.93);
  box-shadow: 0 2rpx 8rpx rgba(39, 174, 96, 0.2);
}

/* ===== 状态标记 ===== */
.status-badge {
  padding: 14rpx 30rpx;
  border-radius: 18rpx;
  font-size: 22px;
  font-weight: 700;
  text-align: center;
}

.status-taken {
  background: linear-gradient(135deg, #e8faf0, #d5f5e3);
  color: #27ae60;
}

.status-missed {
  background: linear-gradient(135deg, #fef0f0, #fde8e8);
  color: #e74c3c;
}

/* ===== 空状态 ===== */
.empty-state {
  text-align: center;
  padding: 120rpx 48rpx;
}

.empty-icon {
  font-size: 80px;
  margin-bottom: 32rpx;
}

.empty-text {
  font-size: 36px;
  color: #555;
  font-weight: 700;
}

/* ===== 药物记忆名称标签 ===== */
.med-cat-row {
  margin-top: 8rpx;
}

.med-cat-label {
  display: inline-block;
  font-size: 20px;
  color: #888;
  background: #f0f2f5;
  padding: 4rpx 18rpx;
  border-radius: 8rpx;
}
