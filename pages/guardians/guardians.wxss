.container {
  min-height: 100vh;
}

/* 守护人卡片 */
.guardian-card {
  margin-bottom: 0;
  margin-top: 16rpx;
  transition: all 0.2s ease;
}

.guardian-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.guardian-info {
  display: flex;
  align-items: center;
}

.guardian-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #f0932b, #e17055);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24px;
  margin-right: 28rpx;
  box-shadow: 0 6rpx 16rpx rgba(225, 112, 85, 0.3);
}

.guardian-detail {
  display: flex;
  flex-direction: column;
}

.guardian-name {
  font-size: 24px;
  font-weight: 600;
  color: #1a1a2e;
}

.guardian-relation {
  font-size: 18px;
  color: #a0a0b8;
  margin-top: 6rpx;
}

/* 操作按钮组 */
.guardian-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.action-btn {
  font-size: 18px;
  padding: 18rpx 28rpx;
  border-radius: 16rpx;
  font-weight: 500;
  transition: all 0.2s ease;
}

.action-btn:active {
  transform: scale(0.92);
}

.action-invite {
  color: #ffffff;
  background: linear-gradient(135deg, #f0932b, #e17055);
}

.action-check {
  color: #4A90D9;
  background: linear-gradient(135deg, #eef4fc, #dce8f8);
}

.action-subscribe {
  color: #2ecc71;
  background: linear-gradient(135deg, #e8faf0, #d5f5e3);
}

.action-edit {
  color: #4A90D9;
  background: linear-gradient(135deg, #eef4fc, #dce8f8);
}

.action-delete {
  color: #e74c3c;
  background: linear-gradient(135deg, #fef0f0, #fde8e8);
}

/* 表单 */
.form-title {
  font-size: 24px;
  font-weight: 700;
  margin-bottom: 32rpx;
  color: #1a1a2e;
}

.form-group {
  margin-bottom: 32rpx;
}

.form-label {
  font-size: 20px;
  color: #555;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.form-input {
  width: 100%;
  height: 104rpx;
  line-height: 104rpx;
  padding: 0 32rpx;
  border: 2rpx solid #e8e8f0;
  border-radius: 20rpx;
  font-size: 22px;
  box-sizing: border-box;
  background: #f8f9fc;
}

/* 关系选项按钮组 */
.relation-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.relation-option {
  flex: 1;
  min-width: 120rpx;
  height: 100rpx;
  line-height: 100rpx;
  text-align: center;
  font-size: 22px;
  font-weight: 500;
  border-radius: 20rpx;
  background: #f8f9fc;
  border: 2rpx solid #e8e8f0;
  color: #444;
  transition: all 0.2s ease;
}

.relation-option.selected {
  background: linear-gradient(135deg, #4A90D9, #5BA3EC);
  border-color: #4A90D9;
  color: #ffffff;
  font-weight: 700;
  box-shadow: 0 6rpx 16rpx rgba(74, 144, 217, 0.35);
}

.relation-option:active {
  transform: scale(0.94);
}

/* 自定义关系输入 */
.custom-relation-wrap {
  margin-top: 20rpx;
}

.custom-relation-input {
  font-size: 20px;
}

.form-actions {
  display: flex;
  gap: 24rpx;
}

.form-actions button {
  flex: 1;
}

/* 邀请面板 */
.invite-steps {
  margin: 24rpx 0;
}

.invite-step {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.step-num {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4A90D9, #5BA3EC);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  font-weight: 700;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.step-text {
  font-size: 20px;
  color: #444;
  line-height: 1.6;
}

/* 邀请码展示 */
.invite-code-box {
  background: linear-gradient(135deg, #f0f6ff, #e8f0fe);
  border: 2rpx solid rgba(74, 144, 217, 0.2);
  border-radius: 20rpx;
  padding: 32rpx;
  text-align: center;
  margin-bottom: 28rpx;
}

.invite-code-label {
  font-size: 18px;
  color: #a0a0b8;
  margin-bottom: 12rpx;
}

.invite-code-value {
  font-size: 20px;
  font-weight: 700;
  color: #4A90D9;
  word-break: break-all;
  line-height: 1.6;
}

/* 邀请面板操作 */
.invite-actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 32rpx;
}

.invite-actions button {
  width: 100%;
}

.btn-share {
  font-size: 22px;
}

.btn-copy {
  font-size: 22px;
}

.invite-close {
  text-align: center;
  margin-top: 24rpx;
  font-size: 20px;
  color: #a0a0b8;
  padding: 16rpx 0;
}

/* 添加按钮 */
.add-btn-wrap {
  padding: 0 24rpx;
}

.btn-input-code {
  margin-top: 20rpx;
  font-size: 20px;
}

/* 使用提示 */
.tips {
  margin-top: 40rpx;
}

.tips-title {
  font-size: 22px;
  font-weight: 600;
  color: #1a1a2e;
  margin-bottom: 16rpx;
}

.tips-text {
  font-size: 18px;
  color: #a0a0b8;
  line-height: 2.2;
}
