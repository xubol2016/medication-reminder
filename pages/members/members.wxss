.container {
  min-height: 100vh;
}

/* ===== 成员卡片 ===== */
.member-card {
  margin-bottom: 0;
  margin-top: 20rpx;
  transition: all 0.2s ease;
}

.member-card:active {
  transform: scale(0.98);
}

.member-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.member-info {
  display: flex;
  align-items: center;
}

.member-avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #5BA3EC, #4A90D9);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32px;
  font-weight: 700;
  margin-right: 32rpx;
  box-shadow: 0 6rpx 16rpx rgba(74, 144, 217, 0.3);
}

.member-detail {
  display: flex;
  flex-direction: column;
}

.member-name {
  font-size: 32px;
  font-weight: 700;
  color: #1a1a2e;
}

.member-role {
  font-size: 22px;
  color: #4A90D9;
  margin-top: 8rpx;
  font-weight: 500;
}

.member-actions {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  font-size: 24px;
  padding: 20rpx 32rpx;
  border-radius: 16rpx;
  font-weight: 600;
  transition: all 0.2s ease;
}

.action-btn:active {
  transform: scale(0.92);
}

.action-edit {
  color: #4A90D9;
  background: linear-gradient(135deg, #eef4fc, #dce8f8);
}

.action-delete {
  color: #e74c3c;
  background: linear-gradient(135deg, #fef0f0, #fde8e8);
}

/* ===== 表单卡片 ===== */
.form-card {
  margin-top: 24rpx;
  border: 2rpx solid rgba(74, 144, 217, 0.15);
}

.form-title {
  font-size: 30px;
  font-weight: 700;
  margin-bottom: 28rpx;
  color: #1a1a2e;
}

.form-actions {
  display: flex;
  gap: 24rpx;
}

.form-actions button {
  flex: 1;
}

/* ===== 副成员提示条 ===== */
.secondary-banner {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #e8f4f8, #d4ecf7);
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 24rpx;
}

.secondary-banner-icon {
  font-size: 30px;
  margin-right: 20rpx;
}

.secondary-banner-text {
  font-size: 26px;
  color: #2c3e50;
  font-weight: 600;
}

/* ===== 分区标题 ===== */
.section-divider {
  height: 2rpx;
  background: linear-gradient(90deg, transparent, #d0d0e0, transparent);
  margin: 48rpx 0 32rpx;
}

.section-title-row {
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 32px;
  font-weight: 700;
  color: #1a1a2e;
}

.section-hint {
  font-size: 26px;
  color: #666;
  margin-bottom: 24rpx;
  line-height: 1.7;
}

/* ===== 副成员卡片 ===== */
.secondary-card {
  margin-top: 20rpx;
}

.secondary-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.secondary-info {
  display: flex;
  align-items: center;
}

.secondary-status-dot {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.dot-bound {
  background: #2ecc71;
}

.dot-pending {
  background: #f0932b;
}

.secondary-name {
  font-size: 30px;
  font-weight: 700;
  color: #1a1a2e;
  margin-right: 16rpx;
}

.secondary-status-label {
  font-size: 22px;
  color: #888;
  font-weight: 500;
}

.secondary-actions {
  display: flex;
  gap: 18rpx;
}

.secondary-btn-wrap {
  padding: 0 24rpx;
}

.mt-12 {
  margin-top: 16rpx;
}

/* ===== 邀请面板 ===== */
.tp-panel-title {
  font-size: 32px;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 32rpx;
}

.invite-code-display {
  background: linear-gradient(135deg, #f0f6ff, #e8f0fe);
  border: 2rpx solid rgba(74, 144, 217, 0.2);
  border-radius: 20rpx;
  padding: 36rpx;
  text-align: center;
  font-size: 26px;
  font-weight: 700;
  color: #4A90D9;
  word-break: break-all;
  margin: 24rpx 0;
  line-height: 1.6;
}

.invite-tips {
  font-size: 26px;
  color: #666;
  text-align: center;
  line-height: 1.7;
  margin-bottom: 8rpx;
}
