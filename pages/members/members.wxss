.container {
  min-height: 100vh;
}

.member-card {
  margin-bottom: 0;
  margin-top: 16rpx;
  transition: all 0.2s ease;
}

.member-card:active {
  transform: scale(0.98);
}

.member-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.member-info {
  display: flex;
  align-items: center;
}

.member-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #5BA3EC, #4A90D9);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24px;
  font-weight: 700;
  margin-right: 28rpx;
  box-shadow: 0 6rpx 16rpx rgba(74, 144, 217, 0.3);
}

.member-name {
  font-size: 22px;
  font-weight: 600;
  color: #1a1a2e;
}

.member-actions {
  display: flex;
  gap: 18rpx;
}

.action-btn {
  font-size: 18px;
  padding: 16rpx 28rpx;
  border-radius: 14rpx;
  font-weight: 500;
  transition: all 0.2s ease;
}

.action-btn:active {
  transform: scale(0.92);
}

.action-edit {
  color: #4A90D9;
  background: linear-gradient(135deg, #eef4fc, #dce8f8);
}

.action-delete {
  color: #e74c3c;
  background: linear-gradient(135deg, #fef0f0, #fde8e8);
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 48px;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 22px;
  color: #a0a0b8;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.empty-hint {
  font-size: 18px;
  color: #c8c8d8;
}

/* 表单 */
.form-card {
  margin-top: 24rpx;
  border: 2rpx solid rgba(74, 144, 217, 0.15);
}

.form-title {
  font-size: 22px;
  font-weight: 700;
  margin-bottom: 24rpx;
  color: #1a1a2e;
}

.form-actions {
  display: flex;
  gap: 24rpx;
}

.form-actions button {
  flex: 1;
}

.add-btn-wrap {
  padding: 0 24rpx;
}
