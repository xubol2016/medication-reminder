/* 全局样式 - 简约现代风格 + 适老化设计 */
page {
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  font-size: 18px;
  color: #1a1a2e;
  background: linear-gradient(180deg, #e8f0fe 0%, #f8f9fc 40%, #ffffff 100%);
  line-height: 1.6;
  min-height: 100vh;
}

/* 通用按钮样式 - 大按钮易点击 + 微交互 */
.btn-primary {
  background: linear-gradient(135deg, #5B9FE6 0%, #4A90D9 50%, #3A7BC8 100%);
  color: #ffffff;
  border: none;
  border-radius: 20rpx;
  padding: 24rpx 40rpx;
  font-size: 18px;
  font-weight: 600;
  text-align: center;
  min-height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(74, 144, 217, 0.3);
  transition: all 0.2s ease;
}

.btn-primary:active {
  transform: scale(0.96);
  box-shadow: 0 4rpx 12rpx rgba(74, 144, 217, 0.2);
}

.btn-danger {
  background: linear-gradient(135deg, #EF5B5B 0%, #E74C3C 100%);
  color: #ffffff;
  border: none;
  border-radius: 20rpx;
  padding: 24rpx 40rpx;
  font-size: 18px;
  font-weight: 600;
  text-align: center;
  min-height: 96rpx;
  box-shadow: 0 8rpx 24rpx rgba(231, 76, 60, 0.25);
  transition: all 0.2s ease;
}

.btn-danger:active {
  transform: scale(0.96);
}

.btn-secondary {
  background-color: #ffffff;
  color: #4A90D9;
  border: 2rpx solid #d0e2f5;
  border-radius: 20rpx;
  padding: 24rpx 40rpx;
  font-size: 18px;
  font-weight: 600;
  text-align: center;
  min-height: 96rpx;
  transition: all 0.2s ease;
}

.btn-secondary:active {
  transform: scale(0.96);
  background-color: #f0f6fd;
}

/* 卡片样式 - 柔和阴影 + 大圆角 */
.card {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin: 20rpx 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(26, 26, 46, 0.06), 0 1rpx 4rpx rgba(26, 26, 46, 0.04);
  transition: all 0.2s ease;
}

/* 表单样式 */
.form-group {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f2f5;
}

.form-group:last-of-type {
  border-bottom: none;
}

.form-label {
  font-size: 18px;
  color: #8c8ca1;
  margin-bottom: 12rpx;
  font-weight: 500;
  letter-spacing: 1rpx;
}

.form-input {
  font-size: 18px;
  height: 96rpx;
  line-height: 96rpx;
  padding: 0 24rpx;
  width: 100%;
  color: #1a1a2e;
  background: #f5f7fa;
  border-radius: 16rpx;
  border: 2rpx solid #e8eaed;
  box-sizing: border-box;
  margin-top: 8rpx;
}

/* 状态颜色 */
.text-success { color: #2ecc71; }
.text-warning { color: #f0932b; }
.text-danger { color: #e74c3c; }
.text-muted { color: #a0a0b8; }

/* 守护人只读模式横幅 */
.guardian-banner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, #f0932b 0%, #f8b500 100%);
  color: #ffffff;
  padding: 20rpx 32rpx;
  margin: 0 24rpx 20rpx;
  border-radius: 20rpx;
  box-shadow: 0 6rpx 20rpx rgba(240, 147, 43, 0.3);
  font-size: 16px;
  font-weight: 600;
}

.guardian-banner-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.guardian-banner-icon {
  font-size: 20px;
  margin-right: 12rpx;
}

.guardian-banner-text {
  flex: 1;
}

/* 待服状态标记（守护人只读模式） */
.status-pending {
  color: #a0a0b8;
  font-size: 16px;
  font-weight: 500;
}

/* 副成员只读模式横幅 */
.secondary-banner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, #4A90D9 0%, #5BA3EC 100%);
  color: #ffffff;
  padding: 20rpx 32rpx;
  margin: 0 24rpx 20rpx;
  border-radius: 20rpx;
  box-shadow: 0 6rpx 20rpx rgba(74, 144, 217, 0.3);
  font-size: 16px;
  font-weight: 600;
}

.secondary-banner-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.secondary-banner-icon {
  font-size: 20px;
  margin-right: 12rpx;
}

.secondary-banner-text {
  flex: 1;
}

.refresh-btn {
  background: rgba(255, 255, 255, 0.25);
  padding: 12rpx 24rpx;
  border-radius: 12rpx;
  font-size: 15px;
  font-weight: 600;
  flex-shrink: 0;
}

.refresh-btn:active {
  background: rgba(255, 255, 255, 0.4);
}

/* Bottom-Sheet Modal */
.tp-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 999;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.tp-panel {
  background: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx 32rpx calc(40rpx + env(safe-area-inset-bottom));
  width: 100%;
  max-height: 80vh;
  overflow-y: auto;
}

.tp-panel-title {
  font-size: 22px;
  font-weight: 700;
  color: #1a1a2e;
  text-align: center;
  margin-bottom: 24rpx;
}

/* 间距工具类 */
.mt-20 { margin-top: 20rpx; }
.mb-20 { margin-bottom: 20rpx; }
.p-24 { padding: 24rpx; }
