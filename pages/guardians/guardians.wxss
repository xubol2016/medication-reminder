.container {
  min-height: 100vh;
}

/* 守护人卡片 */
.guardian-card {
  margin-bottom: 0;
  margin-top: 20rpx;
  transition: all 0.2s ease;
}

.guardian-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.guardian-info {
  display: flex;
  align-items: center;
}

.guardian-avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #f0932b, #e17055);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32px;
  margin-right: 32rpx;
  box-shadow: 0 6rpx 16rpx rgba(225, 112, 85, 0.3);
}

.guardian-detail {
  display: flex;
  flex-direction: column;
}

.guardian-name {
  font-size: 32px;
  font-weight: 700;
  color: #1a1a2e;
}

.guardian-relation {
  font-size: 24px;
  color: #a0a0b8;
  margin-top: 8rpx;
}

/* 状态徽章 */
.guardian-status {
  font-size: 22px;
  padding: 16rpx 32rpx;
  border-radius: 24rpx;
  font-weight: 600;
}

.status-bound {
  color: #2ecc71;
  background: linear-gradient(135deg, #e8faf0, #d5f5e3);
}

.status-pending {
  color: #f0932b;
  background: linear-gradient(135deg, #fef9e7, #fdebd0);
}

/* 操作按钮组 */
.guardian-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.action-btn {
  font-size: 22px;
  padding: 22rpx 32rpx;
  border-radius: 18rpx;
  font-weight: 600;
  transition: all 0.2s ease;
}

.action-btn:active {
  transform: scale(0.92);
}

.action-invite {
  color: #ffffff;
  background: linear-gradient(135deg, #f0932b, #e17055);
}

.action-check {
  color: #4A90D9;
  background: linear-gradient(135deg, #eef4fc, #dce8f8);
}

.action-subscribe {
  color: #2ecc71;
  background: linear-gradient(135deg, #e8faf0, #d5f5e3);
}

/* 守护人配额标签 */
.guardian-quota {
  font-size: 22px;
  font-weight: 700;
  padding: 14rpx 28rpx;
  border-radius: 18rpx;
  align-self: center;
}

.quota-ok {
  color: #2ecc71;
  background: linear-gradient(135deg, #e8faf0, #d5f5e3);
}

.quota-warn {
  color: #f0932b;
  background: linear-gradient(135deg, #fff5e6, #ffe8cc);
}

.quota-empty {
  color: #e74c3c;
  background: linear-gradient(135deg, #fef0f0, #fde8e8);
}

.action-edit {
  color: #4A90D9;
  background: linear-gradient(135deg, #eef4fc, #dce8f8);
}

.action-delete {
  color: #e74c3c;
  background: linear-gradient(135deg, #fef0f0, #fde8e8);
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 80px;
  margin-bottom: 32rpx;
}

.empty-text {
  font-size: 36px;
  color: #555;
  margin-bottom: 20rpx;
  font-weight: 700;
}

.empty-hint {
  font-size: 28px;
  color: #888;
  padding: 0 40rpx;
  line-height: 1.8;
}

/* 底部弹窗 */
.tp-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
  display: flex;
  align-items: flex-end;
}

.tp-panel {
  width: 100%;
  background: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 48rpx;
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

/* 表单 */
.form-title {
  font-size: 32px;
  font-weight: 700;
  margin-bottom: 36rpx;
  color: #1a1a2e;
}

.form-group {
  margin-bottom: 36rpx;
}

.form-label {
  font-size: 26px;
  color: #555;
  margin-bottom: 18rpx;
  font-weight: 600;
}

.form-input {
  width: 100%;
  height: 112rpx;
  line-height: 112rpx;
  padding: 0 32rpx;
  border: 2rpx solid #e8e8f0;
  border-radius: 20rpx;
  font-size: 26px;
  box-sizing: border-box;
  background: #f8f9fc;
}

/* 关系选项按钮组 */
.relation-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.relation-option {
  flex: 1;
  min-width: 120rpx;
  height: 112rpx;
  line-height: 112rpx;
  text-align: center;
  font-size: 26px;
  font-weight: 600;
  border-radius: 20rpx;
  background: #f8f9fc;
  border: 2rpx solid #e8e8f0;
  color: #444;
  transition: all 0.2s ease;
}

.relation-option.selected {
  background: linear-gradient(135deg, #4A90D9, #5BA3EC);
  border-color: #4A90D9;
  color: #ffffff;
  font-weight: 700;
  box-shadow: 0 6rpx 16rpx rgba(74, 144, 217, 0.35);
}

.relation-option:active {
  transform: scale(0.94);
}

/* 自定义关系输入 */
.custom-relation-wrap {
  margin-top: 20rpx;
}

.custom-relation-input {
  font-size: 26px;
}

.form-actions {
  display: flex;
  gap: 24rpx;
}

.form-actions button {
  flex: 1;
}

/* 邀请面板 */
.invite-steps {
  margin: 28rpx 0;
}

.invite-step {
  display: flex;
  align-items: flex-start;
  margin-bottom: 28rpx;
}

.step-num {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4A90D9, #5BA3EC);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24px;
  font-weight: 700;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.step-text {
  font-size: 26px;
  color: #444;
  line-height: 1.7;
  padding-top: 8rpx;
}

/* 邀请码展示 */
.invite-code-box {
  background: linear-gradient(135deg, #f0f6ff, #e8f0fe);
  border: 2rpx solid rgba(74, 144, 217, 0.2);
  border-radius: 20rpx;
  padding: 36rpx;
  text-align: center;
  margin-bottom: 28rpx;
}

.invite-code-label {
  font-size: 24px;
  color: #a0a0b8;
  margin-bottom: 16rpx;
}

.invite-code-value {
  font-size: 26px;
  font-weight: 700;
  color: #4A90D9;
  word-break: break-all;
  line-height: 1.6;
}

/* 邀请面板操作 */
.invite-actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 32rpx;
}

.invite-actions button {
  width: 100%;
}

.btn-share {
  font-size: 26px;
}

.btn-copy {
  font-size: 26px;
}

.invite-close {
  text-align: center;
  margin-top: 24rpx;
  font-size: 26px;
  color: #a0a0b8;
  padding: 20rpx 0;
}

/* 添加按钮 */
.add-btn-wrap {
  padding: 0 24rpx;
}

.btn-input-code {
  margin-top: 20rpx;
  font-size: 22px;
}

/* 使用提示 */
.tips {
  margin-top: 40rpx;
}

.tips-title {
  font-size: 28px;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 20rpx;
}

.tips-text {
  font-size: 24px;
  color: #888;
  line-height: 2.2;
}
