.container {
  min-height: 100vh;
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
}

/* ===== 月份栏 ===== */
.month-bar {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 28rpx 28rpx 36rpx;
  background: linear-gradient(135deg, #4A90D9, #5BA3EC);
  gap: 16rpx;
}

.month-bar-title {
  font-size: 56rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 4rpx;
}

.month-nav {
  display: flex;
  align-items: center;
  gap: 48rpx;
}

.month-btn {
  font-size: 28px;
  color: rgba(255, 255, 255, 0.9);
  padding: 16rpx 32rpx;
  border-radius: 14rpx;
  transition: all 0.2s ease;
}

.month-btn:active {
  transform: scale(0.9);
  background: rgba(255, 255, 255, 0.15);
}

.month-text {
  font-size: 32px;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 2rpx;
}

/* ===== 日历卡片 ===== */
.calendar {
  margin-top: 24rpx;
  padding: 24rpx;
}

.cal-header {
  display: flex;
  margin-bottom: 8rpx;
}

.cal-header-cell {
  flex: 1;
  text-align: center;
  font-size: 22px;
  color: #888;
  padding: 14rpx 0;
  font-weight: 700;
}

.cal-body {
  display: flex;
  flex-wrap: wrap;
}

.cal-cell {
  width: 14.285%;
  text-align: center;
  padding: 10rpx 0;
  position: relative;
}

.cal-day {
  display: inline-block;
  width: 80rpx;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 50%;
  font-size: 22px;
  color: #1a1a2e;
  font-weight: 500;
  transition: all 0.2s ease;
}

.cal-today .cal-day {
  color: #4A90D9;
  font-weight: 700;
  background: rgba(74, 144, 217, 0.08);
}

.cal-selected .cal-day {
  background: linear-gradient(135deg, #4A90D9, #5BA3EC);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(74, 144, 217, 0.35);
}

.cal-empty {
  visibility: hidden;
}

.cal-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin: 6rpx auto 0;
  background: #d0d0d8;
}

.dot-green { background: #2ecc71; }
.dot-red   { background: #e74c3c; }

/* ===== 成员 Tab ===== */
.member-tabs {
  white-space: nowrap;
  padding: 24rpx 24rpx 12rpx;
}

.tab {
  display: inline-block;
  padding: 20rpx 44rpx;
  margin-right: 16rpx;
  border-radius: 40rpx;
  font-size: 24px;
  color: #6b6b80;
  background: #ffffff;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  font-weight: 600;
  transition: all 0.2s ease;
}

.tab:active {
  transform: scale(0.95);
}

.tab-active {
  background: linear-gradient(135deg, #4A90D9, #5BA3EC);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(74, 144, 217, 0.3);
}

/* ===== 当日摘要卡片 ===== */
.day-card {
  margin-top: 16rpx;
}

.day-summary {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.day-date-wrap {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.day-date-icon {
  font-size: 26px;
}

.day-date {
  font-size: 26px;
  font-weight: 700;
  color: #1a1a2e;
}

.day-rate-badge {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: linear-gradient(135deg, #e8faf0, #d5f5e3);
  padding: 14rpx 32rpx;
  border-radius: 24rpx;
}

.day-rate {
  font-size: 26px;
  color: #27ae60;
  font-weight: 700;
}

.day-rate-label {
  font-size: 22px;
  color: #27ae60;
}

/* ===== 记录列表 ===== */
.record-list {
  padding: 0;
}

.record-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 12rpx;
  padding: 32rpx;
}

.record-left {
  display: flex;
  align-items: center;
  gap: 24rpx;
  flex: 1;
}

.record-time-badge {
  background: linear-gradient(135deg, #eef4fc, #dce8f8);
  padding: 14rpx 24rpx;
  border-radius: 14rpx;
  min-width: 120rpx;
  text-align: center;
  flex-shrink: 0;
}

.record-time {
  font-size: 26px;
  font-weight: 700;
  color: #4A90D9;
}

.record-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  flex: 1;
}

.record-name {
  font-size: 28px;
  font-weight: 700;
  color: #1a1a2e;
}

.record-member {
  font-size: 22px;
  color: #888;
}

.record-sub-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 4rpx;
}

.record-dosage {
  font-size: 22px;
  color: #888;
}

.record-cat-label {
  display: inline-block;
  font-size: 20px;
  color: #888;
  background: #f0f2f5;
  padding: 4rpx 18rpx;
  border-radius: 8rpx;
  margin-top: 4rpx;
}

.record-status {
  flex-shrink: 0;
  margin-left: 16rpx;
}

/* ===== 状态标签 ===== */
.status-pill {
  padding: 14rpx 30rpx;
  border-radius: 22rpx;
  font-size: 22px;
  font-weight: 700;
}

.status-pill-taken {
  background: linear-gradient(135deg, #e8faf0, #d5f5e3);
  color: #27ae60;
}

.status-pill-missed {
  background: linear-gradient(135deg, #fef0f0, #fde8e8);
  color: #e74c3c;
}

.status-pill-pending {
  background: #f5f5f8;
  color: #a0a0b8;
}

/* ===== 空状态 ===== */
.empty-hint {
  text-align: center;
  padding: 100rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.empty-hint-icon {
  font-size: 64px;
}

.empty-hint-text {
  color: #888;
  font-size: 28px;
  font-weight: 500;
}
