<view class="container p-24">
  <!-- 守护人提示条 -->
  <view class="guardian-banner" wx:if="{{isGuardian}}">
    <text class="guardian-banner-icon">👁️</text>
    <text class="guardian-banner-text">正在查看 {{guardianOwnerName}} 的设置信息（只读）</text>
  </view>

  <!-- 副成员提示条 -->
  <view class="secondary-banner" wx:if="{{isSecondary}}">
    <view class="secondary-banner-left">
      <text class="secondary-banner-icon">👁️</text>
      <text class="secondary-banner-text">正在查看 {{primaryOwnerName}} 的设置信息（只读）</text>
    </view>
    <view class="refresh-btn" bindtap="manualRefresh">🔄 刷新</view>
  </view>

  <!-- 管理入口 -->
  <view class="section-title">📋 管理</view>
  <!-- 守护人或副成员模式：可点击查看（只读） -->
  <view class="card menu-card" wx:if="{{isGuardian || isSecondary}}">
    <view class="menu-item" bindtap="goMembers">
      <view class="menu-item-left">
        <view class="menu-icon menu-icon-blue">👥</view>
        <text class="menu-text">成员</text>
      </view>
      <view class="menu-item-right">
        <text class="menu-count">{{memberCount}} 人</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
    <view class="menu-item" bindtap="goMedicines">
      <view class="menu-item-left">
        <view class="menu-icon menu-icon-green">💊</view>
        <text class="menu-text">药物</text>
      </view>
      <view class="menu-item-right">
        <text class="menu-count">{{medicineCount}} 种</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>
  <!-- 正常模式：可点击管理 -->
  <view class="card menu-card" wx:else>
    <view class="menu-item" bindtap="goMembers">
      <view class="menu-item-left">
        <view class="menu-icon menu-icon-blue">👥</view>
        <text class="menu-text">成员管理</text>
      </view>
      <view class="menu-item-right">
        <text class="menu-count">{{memberCount}} 人</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
    <view class="menu-item" bindtap="goMedicines">
      <view class="menu-item-left">
        <view class="menu-icon menu-icon-green">💊</view>
        <text class="menu-text">药物管理</text>
      </view>
      <view class="menu-item-right">
        <text class="menu-count">{{medicineCount}} 种</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
    <view class="menu-item" bindtap="goGuardians">
      <view class="menu-item-left">
        <view class="menu-icon menu-icon-orange">🛡️</view>
        <text class="menu-text">守护人管理</text>
      </view>
      <view class="menu-item-right">
        <text class="menu-count">{{guardianCount}} 人</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 数据管理（守护人和副成员模式隐藏） -->
  <block wx:if="{{!isGuardian && !isSecondary}}">
    <view class="section-title">🗂️ 数据</view>
    <view class="card menu-card">
      <view class="menu-item" bindtap="cleanOldData">
        <view class="menu-item-left">
          <view class="menu-icon menu-icon-orange">🧹</view>
          <text class="menu-text">清理历史记录</text>
        </view>
        <view class="menu-item-right">
          <text class="menu-hint">保留近6个月</text>
          <text class="menu-arrow">›</text>
        </view>
      </view>
      <view class="menu-item" bindtap="clearAllData">
        <view class="menu-item-left">
          <view class="menu-icon menu-icon-red">🗑️</view>
          <text class="menu-text text-danger">清除所有数据</text>
        </view>
        <view class="menu-item-right">
          <text class="menu-hint">不可恢复</text>
          <text class="menu-arrow">›</text>
        </view>
      </view>
    </view>
  </block>

  <!-- 通知设置（守护人和副成员模式隐藏） -->
  <block wx:if="{{!isGuardian && !isSecondary}}">
    <view class="section-title">🔔 通知</view>
    <view class="card menu-card">
      <view class="menu-item" bindtap="requestSubscription">
        <view class="menu-item-left">
          <view class="menu-icon menu-icon-green">🔔</view>
          <text class="menu-text">开启服药提醒通知</text>
        </view>
        <view class="menu-item-right">
          <text class="menu-quota {{myRemaining > 3 ? 'quota-ok' : (myRemaining > 0 ? 'quota-warn' : 'quota-empty')}}" wx:if="{{myRemaining >= 0}}">剩余{{myRemaining}}次</text>
          <text class="menu-hint" wx:else>点击授权</text>
          <text class="menu-arrow">›</text>
        </view>
      </view>
      <view class="menu-item" bindtap="showGuardianQuotaTip">
        <view class="menu-item-left">
          <view class="menu-icon menu-icon-orange">📢</view>
          <text class="menu-text">漏服守护通知</text>
        </view>
        <view class="menu-item-right">
          <text class="menu-quota {{guardianTotal > 3 ? 'quota-ok' : (guardianTotal > 0 ? 'quota-warn' : 'quota-empty')}}" wx:if="{{guardianTotal >= 0}}">守护人剩余{{guardianTotal}}次</text>
          <text class="menu-hint" wx:else>由守护人授权</text>
          <text class="menu-arrow">›</text>
        </view>
      </view>
    </view>
  </block>

  <!-- 关于 -->
  <view class="section-title">ℹ️ 关于</view>
  <view class="card menu-card">
    <view class="menu-item">
      <view class="menu-item-left">
        <view class="menu-icon menu-icon-purple">📱</view>
        <text class="menu-text">版本</text>
      </view>
      <text class="menu-hint">v1.0.0</text>
    </view>
  </view>

  <!-- 使用提示 -->
  <view class="tips card">
    <view class="tips-title">💡 使用提示</view>
    <block wx:if="{{isGuardian}}">
      <view class="tips-text">· 您当前以守护人身份查看 {{guardianOwnerName}} 的用药数据</view>
      <view class="tips-text">· 数据为只读模式，无法进行修改操作</view>
      <view class="tips-text">· 当家人漏服药物时，您会收到微信通知提醒</view>
    </block>
    <block wx:elif="{{isSecondary}}">
      <view class="tips-text">· 您当前以副成员身份查看 {{primaryOwnerName}} 的用药数据</view>
      <view class="tips-text">· 数据为只读模式，每60秒自动同步</view>
      <view class="tips-text">· 点击刷新按钮可立即获取最新数据</view>
    </block>
    <block wx:else>
      <view class="tips-text">· 请在服药时间前打开小程序，系统会弹窗提醒</view>
      <view class="tips-text">· 漏服的药物会在下次打开时自动标记</view>
      <view class="tips-text">· 数据存储在本地，清除小程序缓存会丢失数据</view>
      <view class="tips-text">· 添加守护人后，漏服时会自动发送微信提醒给守护人</view>
      <view class="tips-text">· 点击"开启服药提醒通知"可授权微信推送提醒，无需打开小程序也能收到</view>
      <view class="tips-text">· 每次授权可获得1次推送机会，建议多次点击授权</view>
    </block>
  </view>
</view>
