.container {
  min-height: 100vh;
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
}

.section-title {
  font-size: 18px;
  color: #a0a0b8;
  padding: 28rpx 8rpx 12rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
}

.menu-card {
  padding: 0;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid #f5f5f8;
  transition: all 0.2s ease;
}

.menu-item:active {
  background-color: #f8f9fc;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.menu-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24px;
}

.menu-icon-blue { background: linear-gradient(135deg, #eef4fc, #dce8f8); }
.menu-icon-green { background: linear-gradient(135deg, #e8faf0, #d5f5e3); }
.menu-icon-orange { background: linear-gradient(135deg, #fff5e6, #ffe8cc); }
.menu-icon-red { background: linear-gradient(135deg, #fef0f0, #fde8e8); }
.menu-icon-purple { background: linear-gradient(135deg, #f0eeff, #e4e0fd); }

.menu-text {
  font-size: 20px;
  font-weight: 500;
  color: #1a1a2e;
}

.menu-item-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.menu-count {
  font-size: 18px;
  color: #4A90D9;
  font-weight: 600;
  background: linear-gradient(135deg, #eef4fc, #dce8f8);
  padding: 8rpx 24rpx;
  border-radius: 16rpx;
}

.menu-hint {
  font-size: 18px;
  color: #a0a0b8;
}

.menu-quota {
  font-size: 18px;
  font-weight: 600;
  padding: 8rpx 24rpx;
  border-radius: 16rpx;
}

.quota-ok {
  color: #2ecc71;
  background: linear-gradient(135deg, #e8faf0, #d5f5e3);
}

.quota-warn {
  color: #f0932b;
  background: linear-gradient(135deg, #fff5e6, #ffe8cc);
}

.quota-empty {
  color: #e74c3c;
  background: linear-gradient(135deg, #fef0f0, #fde8e8);
}

.menu-arrow {
  font-size: 24px;
  color: #d0d0d8;
  font-weight: 300;
}

.guardian-quota-hint {
  padding: 16rpx 32rpx 0;
  font-size: 14px;
  color: #a0a0b8;
  line-height: 1.6;
}

.tips {
  margin-top: 40rpx;
  background: linear-gradient(135deg, #fffcf0, #fff8e1);
  border: 1rpx solid rgba(240, 147, 43, 0.1);
}

.tips-title {
  font-size: 19px;
  font-weight: 700;
  color: #f0932b;
  margin-bottom: 20rpx;
}

.tips-text {
  font-size: 18px;
  color: #7a6e5a;
  line-height: 2.2;
}
