.container {
  min-height: 100vh;
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
}

/* 成员分组标题 */
.member-group-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 32rpx 8rpx 12rpx;
}

.member-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #5BA3EC, #4A90D9);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
  font-weight: 700;
  box-shadow: 0 4rpx 12rpx rgba(74, 144, 217, 0.3);
  flex-shrink: 0;
}

.member-group-name {
  font-size: 22px;
  font-weight: 700;
  color: #1a1a2e;
  flex: 1;
}

.member-med-count {
  font-size: 18px;
  color: #a0a0b8;
}

/* 药物剂量行 */
.med-dosage-row {
  margin-top: 10rpx;
}

.med-dosage-text {
  font-size: 18px;
  color: #a0a0b8;
}

.med-card {
  margin-bottom: 0;
  margin-top: 16rpx;
  transition: all 0.2s ease;
}

.med-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.med-name-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.med-pill-icon {
  font-size: 22px;
}

.med-name {
  font-size: 22px;
  font-weight: 700;
  color: #1a1a2e;
}

.med-detail {
  margin-top: 12rpx;
  font-size: 18px;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.med-detail-icon {
  font-size: 18px;
}

.med-detail-text {
  color: #a0a0b8;
  font-size: 18px;
}

.med-detail-sep {
  color: #d0d0d8;
}

.med-times {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 20rpx;
}

.time-tag {
  background: linear-gradient(135deg, #eef4fc, #dce8f8);
  color: #4A90D9;
  padding: 12rpx 28rpx;
  border-radius: 20rpx;
  font-size: 18px;
  font-weight: 600;
}

.med-actions {
  display: flex;
  gap: 18rpx;
  border-top: 1rpx solid #f0f2f5;
  padding-top: 24rpx;
  margin-top: 24rpx;
}

.action-btn {
  font-size: 18px;
  padding: 16rpx 28rpx;
  border-radius: 14rpx;
  font-weight: 500;
  transition: all 0.2s ease;
}

.action-btn:active {
  transform: scale(0.92);
}

.action-edit {
  color: #4A90D9;
  background: linear-gradient(135deg, #eef4fc, #dce8f8);
}

.action-delete {
  color: #e74c3c;
  background: linear-gradient(135deg, #fef0f0, #fde8e8);
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 48px;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 22px;
  color: #a0a0b8;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.empty-hint {
  font-size: 18px;
  color: #c8c8d8;
}

/* 表单弹层 */
.form-panel {
  max-height: 80vh;
  display: flex;
  flex-direction: column;
}

.form-scroll {
  height: calc(80vh - 300rpx);
}

.form-title {
  font-size: 22px;
  font-weight: 700;
  margin-bottom: 24rpx;
  color: #1a1a2e;
}

.picker-value {
  font-size: 20px;
  padding: 20rpx 24rpx;
  color: #1a1a2e;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-weight: 500;
  background: #f5f7fa;
  border-radius: 16rpx;
  border: 2rpx solid #e8eaed;
  margin-top: 8rpx;
}

.picker-arrow {
  color: #a0a0b8;
  font-size: 20px;
  margin-left: 12rpx;
}

.time-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.time-item {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #eef4fc, #dce8f8);
  padding: 14rpx 28rpx;
  border-radius: 20rpx;
  font-size: 18px;
  color: #4A90D9;
  font-weight: 600;
}

.time-item-text {
  margin-right: 12rpx;
}

.time-remove {
  margin-left: 8rpx;
  color: #e74c3c;
  font-size: 18px;
  font-weight: 700;
}

.add-time-btn {
  color: #4A90D9;
  font-size: 18px;
  font-weight: 600;
  padding: 20rpx 0;
}

.form-actions {
  display: flex;
  gap: 24rpx;
}

.form-actions button {
  flex: 1;
}

.add-btn-wrap {
  padding: 0 24rpx;
}

/* ====== 自定义弹出面板通用样式 ====== */
.tp-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 999;
}

.tp-panel {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #ffffff;
  border-radius: 36rpx 36rpx 0 0;
  padding: 40rpx 36rpx 60rpx;
  box-shadow: 0 -8rpx 40rpx rgba(0, 0, 0, 0.12);
  z-index: 1000;
}

.tp-title {
  font-size: 24px;
  font-weight: 700;
  color: #1a1a2e;
  text-align: center;
  margin-bottom: 32rpx;
}

/* 成员选择器 */
.mp-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.mp-item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  border-radius: 20rpx;
  background: #f8f9fc;
  transition: all 0.2s ease;
  gap: 24rpx;
}

.mp-item:active {
  transform: scale(0.97);
}

.mp-item-active {
  background: linear-gradient(135deg, #eef4fc, #dce8f8);
  border: 2rpx solid #4A90D9;
}

.mp-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #5BA3EC, #4A90D9);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24px;
  font-weight: 700;
  box-shadow: 0 4rpx 12rpx rgba(74, 144, 217, 0.3);
}

.mp-name {
  font-size: 24px;
  font-weight: 600;
  color: #1a1a2e;
  flex: 1;
}

.mp-check {
  font-size: 24px;
  color: #4A90D9;
  font-weight: 700;
}

/* 常用时间预设 */
.tp-presets {
  display: flex;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.tp-preset-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 28rpx 12rpx;
  background: linear-gradient(135deg, #eef4fc, #dce8f8);
  border-radius: 20rpx;
  transition: all 0.2s ease;
}

.tp-preset-btn:active {
  transform: scale(0.93);
  background: linear-gradient(135deg, #4A90D9, #5BA3EC);
}

.tp-preset-btn:active .tp-preset-label,
.tp-preset-btn:active .tp-preset-time {
  color: #ffffff;
}

.tp-preset-label {
  font-size: 18px;
  color: #6b6b80;
  margin-bottom: 8rpx;
  font-weight: 500;
}

.tp-preset-time {
  font-size: 24px;
  font-weight: 700;
  color: #4A90D9;
}

/* 分割线 */
.tp-divider {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 32rpx;
}

.tp-divider-line {
  flex: 1;
  height: 1rpx;
  background: #eeeeee;
}

.tp-divider-text {
  font-size: 18px;
  color: #a0a0b8;
  font-weight: 500;
}

/* 小时/分钟调节器 */
.tp-spinners {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  margin-bottom: 40rpx;
}

.tp-spinner {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.tp-spin-label {
  font-size: 18px;
  color: #a0a0b8;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.tp-spin-ctrl {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.tp-spin-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #f0f2f5, #e8eaed);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30px;
  font-weight: 700;
  color: #4A90D9;
  transition: all 0.2s ease;
}

.tp-spin-btn:active {
  transform: scale(0.88);
  background: linear-gradient(135deg, #4A90D9, #5BA3EC);
  color: #ffffff;
}

.tp-spin-value {
  width: 110rpx;
  height: 110rpx;
  line-height: 110rpx;
  text-align: center;
  font-size: 42px;
  font-weight: 700;
  color: #1a1a2e;
  background: #f8f9fc;
  border-radius: 20rpx;
  border: 2rpx solid #e8eaed;
}

.tp-colon {
  font-size: 36px;
  font-weight: 700;
  color: #1a1a2e;
  padding-top: 40rpx;
}

/* 底部操作 */
.tp-actions {
  display: flex;
  gap: 24rpx;
}

.tp-action-btn {
  flex: 1;
}

/* ====== 健康小提示功能样式 ====== */

/* 药物卡片上的提示按钮 */
.action-tip {
  color: #27ae60;
  background: linear-gradient(135deg, #edfaf3, #d5f5e3);
}

/* 表单内查询按钮 */
.tip-query-btn {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 20rpx;
  padding: 24rpx 32rpx;
  border-radius: 16rpx;
  background: #f0f2f5;
  border: 2rpx solid #e0e2e8;
  transition: all 0.2s ease;
}

.tip-query-btn-active {
  background: linear-gradient(135deg, #eef4fc, #dce8f8);
  border-color: #4A90D9;
}

.tip-query-btn:active {
  transform: scale(0.96);
}

.tip-query-icon {
  font-size: 20px;
}

.tip-query-text {
  font-size: 18px;
  font-weight: 600;
  color: #4A90D9;
}

/* 已采用提示标记 */
.tip-adopted-badge {
  margin-top: 16rpx;
  padding: 16rpx 24rpx;
  border-radius: 12rpx;
  background: linear-gradient(135deg, #edfaf3, #d5f5e3);
  font-size: 18px;
  color: #27ae60;
  font-weight: 500;
}

/* 加载状态 */
.tip-loading {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-top: 20rpx;
  padding: 28rpx 24rpx;
  background: #f8f9fc;
  border-radius: 16rpx;
}

.tip-loading-spinner {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid #e0e2e8;
  border-top-color: #4A90D9;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  flex-shrink: 0;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.tip-loading-text {
  font-size: 18px;
  color: #a0a0b8;
}

/* 查询结果卡片 */
.tip-result-card {
  margin-top: 20rpx;
  padding: 28rpx 24rpx;
  background: linear-gradient(135deg, #f8fbff, #eef4fc);
  border-radius: 20rpx;
  border: 2rpx solid #d0e4f7;
}

/* 提示内容各节 */
.tip-section {
  margin-bottom: 24rpx;
}

.tip-section-label {
  display: block;
  font-size: 17px;
  font-weight: 700;
  color: #4A90D9;
  margin-bottom: 10rpx;
}

.tip-section-text {
  display: block;
  font-size: 18px;
  color: #2c2c3e;
  line-height: 1.6;
}

.tip-highlight {
  color: #27ae60;
  font-weight: 600;
}

/* 注意事项列表项 */
.tip-caution-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.tip-caution-dot {
  font-size: 22px;
  color: #f0932b;
  line-height: 1.4;
  flex-shrink: 0;
}

.tip-caution-text {
  font-size: 18px;
  color: #2c2c3e;
  line-height: 1.6;
}

/* 采用按钮 */
.tip-adopt-btn {
  margin-top: 20rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #4A90D9, #5BA3EC);
  text-align: center;
  font-size: 18px;
  font-weight: 700;
  color: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(74, 144, 217, 0.35);
  transition: all 0.2s ease;
}

.tip-adopt-btn:active {
  transform: scale(0.95);
}

.tip-adopt-btn-done {
  background: linear-gradient(135deg, #27ae60, #2ecc71);
  box-shadow: 0 4rpx 16rpx rgba(39, 174, 96, 0.35);
}

/* 查看提示弹层 */
.tip-view-panel {
  max-height: 75vh;
  display: flex;
  flex-direction: column;
}

.tip-view-scroll {
  flex: 1;
  height: 0;
  overflow: hidden;
  padding: 0 4rpx;
}

/* ====== 药物名称标签提示 ====== */
.form-label-hint {
  font-size: 15px;
  font-weight: 400;
  color: #a0a0b8;
  margin-left: 8rpx;
}

/* ====== 药物卡片：具体药名标签 ====== */
.med-name-block {
  flex: 1;
}

.med-drug-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 10rpx;
}

.med-drug-tag {
  font-size: 15px;
  color: #4A90D9;
  background: linear-gradient(135deg, #eef4fc, #dce8f8);
  padding: 4rpx 20rpx;
  border-radius: 12rpx;
  font-weight: 500;
}

/* ====== 具体药名输入区域 ====== */
.drug-name-item {
  margin-bottom: 28rpx;
}

.drug-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.drug-name-num {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4A90D9, #5BA3EC);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 17px;
  font-weight: 700;
  flex-shrink: 0;
}

.drug-name-input {
  flex: 1;
  background: #f5f7fa;
  border: 2rpx solid #e8eaed;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 18px;
  color: #1a1a2e;
  height: 88rpx;
  line-height: 88rpx;
}

.drug-name-del {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #fef0f0, #fde8e8);
  color: #e74c3c;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
  font-weight: 700;
  flex-shrink: 0;
}

.drug-name-del:active {
  transform: scale(0.88);
}

/* 继续添加药名按钮 */
.add-drug-name-btn {
  color: #4A90D9;
  font-size: 18px;
  font-weight: 600;
  padding: 16rpx 0 8rpx;
}

/* ====== 查看提示弹层：多药名块 ====== */
.tip-drug-block {
  padding: 28rpx 24rpx;
  margin-bottom: 24rpx;
  background: linear-gradient(135deg, #f8fbff, #eef4fc);
  border-radius: 20rpx;
  border: 2rpx solid #d0e4f7;
}

.tip-drug-block:last-child {
  margin-bottom: 0;
}

.tip-drug-name-badge {
  display: inline-block;
  font-size: 18px;
  font-weight: 700;
  color: #ffffff;
  background: linear-gradient(135deg, #4A90D9, #5BA3EC);
  padding: 10rpx 28rpx;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
}

/* ====== 具体药名内部：剂量与时间 ====== */
.drug-sub-fields {
  margin-top: 16rpx;
  padding: 20rpx 24rpx;
  background: #f8f9fc;
  border-radius: 16rpx;
  border: 2rpx solid #eef0f5;
}

.drug-sub-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #eef0f5;
}

.drug-sub-row:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.drug-times-row {
  align-items: flex-start;
}

.drug-sub-label {
  font-size: 17px;
  color: #6b6b80;
  font-weight: 500;
  flex-shrink: 0;
  width: 144rpx;
  padding-top: 4rpx;
}

.drug-sub-input {
  flex: 1;
  background: #ffffff;
  border: 2rpx solid #e8eaed;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 18px;
  color: #1a1a2e;
  height: 80rpx;
  line-height: 80rpx;
}

.drug-times-wrap {
  flex: 1;
}
