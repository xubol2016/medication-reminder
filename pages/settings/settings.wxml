<view class="container p-24">
  <!-- 守护人提示条 -->
  <view class="guardian-banner" wx:if="{{isGuardian}}">
    <text class="guardian-banner-icon">👁️</text>
    <text class="guardian-banner-text">正在查看 {{guardianOwnerName}} 的设置信息（只读）</text>
  </view>

  <!-- 副成员提示条 -->
  <view class="secondary-banner" wx:if="{{isSecondary}}">
    <view class="secondary-banner-left">
      <text class="secondary-banner-icon">👁️</text>
      <text class="secondary-banner-text">正在查看 {{primaryOwnerName}} 的设置信息（只读）</text>
    </view>
    <view class="refresh-btn" bindtap="manualRefresh">🔄 刷新</view>
  </view>

  <!-- 管理入口 -->
  <view class="section-title">📋 管理</view>
  <!-- 守护人或副成员模式：可点击查看（只读） -->
  <van-cell-group inset round wx:if="{{isGuardian || isSecondary}}">
    <van-cell title="成员" icon="👥" is-link bind:click="goMembers" value="{{memberCount}} 人" />
    <van-cell title="药物" icon="💊" is-link bind:click="goMedicines" value="{{medicineCount}} 种" />
  </van-cell-group>
  <!-- 正常模式：可点击管理 -->
  <van-cell-group inset round wx:else>
    <van-cell title="成员管理" icon="👥" is-link bind:click="goMembers" value="{{memberCount}} 人" />
    <van-cell title="药物管理" icon="💊" is-link bind:click="goMedicines" value="{{medicineCount}} 种" />
    <van-cell title="守护人管理" icon="🛡️" is-link bind:click="goGuardians" value="{{guardianCount}} 人" />
  </van-cell-group>

  <!-- 数据管理（守护人和副成员模式隐藏） -->
  <block wx:if="{{!isGuardian && !isSecondary}}">
    <view class="section-title">🗂️ 数据</view>
    <van-cell-group inset round>
      <van-cell title="清理历史记录" icon="🧹" is-link bind:click="cleanOldData" label="保留近6个月" />
      <van-cell title="清除所有数据" title-class="text-danger" icon="🗑️" is-link bind:click="clearAllData" label="不可恢复" />
    </van-cell-group>
  </block>

  <!-- 守护人提醒配额（仅守护人模式显示） -->
  <block wx:if="{{isGuardian}}">
    <view class="section-title">🔔 我的提醒配额</view>
    <van-cell-group inset round>
      <van-cell title="增加提醒配额" icon="🔔" is-link bind:click="requestSubscription">
        <van-tag slot="value" wx:if="{{myRemaining >= 0}}" type="{{myRemaining > 3 ? 'success' : (myRemaining > 0 ? 'warning' : 'danger')}}" size="medium">剩余{{myRemaining}}次</van-tag>
        <text slot="value" wx:else class="menu-hint">点击授权</text>
      </van-cell>
    </van-cell-group>
    <view class="guardian-quota-hint">
      <text>💡 每次点击授权可增加1次漏服提醒接收次数，配额用完后将无法收到通知</text>
    </view>
  </block>

  <!-- 副成员提醒配额 -->
  <block wx:if="{{isSecondary}}">
    <view class="section-title">🔔 我的提醒配额</view>
    <van-cell-group inset round>
      <van-cell title="增加提醒配额" icon="🔔" is-link bind:click="requestSubscription">
        <van-tag slot="value" wx:if="{{myRemaining >= 0}}" type="{{myRemaining > 3 ? 'success' : (myRemaining > 0 ? 'warning' : 'danger')}}" size="medium">剩余{{myRemaining}}次</van-tag>
        <text slot="value" wx:else class="menu-hint">点击授权</text>
      </van-cell>
    </van-cell-group>
    <view class="guardian-quota-hint">
      <text>💡 每次点击授权可增加1次服药提醒接收次数，配额用完后将无法收到通知</text>
    </view>
  </block>

  <!-- 通知设置（守护人和副成员模式隐藏） -->
  <block wx:if="{{!isGuardian && !isSecondary}}">
    <view class="section-title">🔔 通知</view>
    <van-cell-group inset round>
      <van-cell title="开启服药提醒通知" icon="🔔" is-link bind:click="requestSubscription">
        <van-tag slot="value" wx:if="{{myRemaining >= 0}}" type="{{myRemaining > 3 ? 'success' : (myRemaining > 0 ? 'warning' : 'danger')}}" size="medium">剩余{{myRemaining}}次</van-tag>
        <text slot="value" wx:else class="menu-hint">点击授权</text>
      </van-cell>
      <van-cell title="漏服守护通知" icon="📢" is-link bind:click="showGuardianQuotaTip">
        <van-tag slot="value" wx:if="{{guardianTotal >= 0}}" type="{{guardianTotal > 3 ? 'success' : (guardianTotal > 0 ? 'warning' : 'danger')}}" size="medium">守护人剩余{{guardianTotal}}次</van-tag>
        <text slot="value" wx:else class="menu-hint">由守护人授权</text>
      </van-cell>
    </van-cell-group>
  </block>

  <!-- 关于 -->
  <view class="section-title">ℹ️ 关于</view>
  <van-cell-group inset round>
    <van-cell title="版本" icon="📱" value="v1.0.0" />
  </van-cell-group>

  <!-- 使用提示 -->
  <view class="tips card">
    <view class="tips-title">💡 使用提示</view>
    <block wx:if="{{isGuardian}}">
      <view class="tips-text">· 您当前以守护人身份查看 {{guardianOwnerName}} 的用药数据</view>
      <view class="tips-text">· 数据为只读模式，无法进行修改操作</view>
      <view class="tips-text">· 当家人漏服药物时，您会收到微信通知提醒</view>
      <view class="tips-text">· 点击上方「增加提醒配额」可获取更多漏服通知次数</view>
    </block>
    <block wx:elif="{{isSecondary}}">
      <view class="tips-text">· 您当前以副成员身份查看 {{primaryOwnerName}} 的用药数据</view>
      <view class="tips-text">· 数据为只读模式，每60秒自动同步</view>
      <view class="tips-text">· 点击刷新按钮可立即获取最新数据</view>
    </block>
    <block wx:else>
      <view class="tips-text">· 请在服药时间前打开小程序，系统会弹窗提醒</view>
      <view class="tips-text">· 漏服的药物会在下次打开时自动标记</view>
      <view class="tips-text">· 数据存储在本地，清除小程序缓存会丢失数据</view>
      <view class="tips-text">· 添加守护人后，漏服时会自动发送微信提醒给守护人</view>
      <view class="tips-text">· 点击"开启服药提醒通知"可授权微信推送提醒，无需打开小程序也能收到</view>
      <view class="tips-text">· 每次授权可获得1次推送机会，建议多次点击授权</view>
    </block>
  </view>
</view>
