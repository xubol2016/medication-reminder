.container {
  min-height: 100vh;
}

.member-card {
  margin-bottom: 0;
  margin-top: 16rpx;
  transition: all 0.2s ease;
}

.member-card:active {
  transform: scale(0.98);
}

.member-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.member-info {
  display: flex;
  align-items: center;
}

.member-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #5BA3EC, #4A90D9);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24px;
  font-weight: 700;
  margin-right: 28rpx;
  box-shadow: 0 6rpx 16rpx rgba(74, 144, 217, 0.3);
}

.member-detail {
  display: flex;
  flex-direction: column;
}

.member-name {
  font-size: 22px;
  font-weight: 600;
  color: #1a1a2e;
}


.member-actions {
  display: flex;
  gap: 18rpx;
}

.action-btn {
  font-size: 18px;
  padding: 16rpx 28rpx;
  border-radius: 14rpx;
  font-weight: 500;
  transition: all 0.2s ease;
}

.action-btn:active {
  transform: scale(0.92);
}

.action-edit {
  color: #4A90D9;
  background: linear-gradient(135deg, #eef4fc, #dce8f8);
}

.action-delete {
  color: #e74c3c;
  background: linear-gradient(135deg, #fef0f0, #fde8e8);
}

/* (empty-state removed, using inline button instead) */

/* 表单 */
.form-card {
  margin-top: 24rpx;
  border: 2rpx solid rgba(74, 144, 217, 0.15);
}

.form-title {
  font-size: 22px;
  font-weight: 700;
  margin-bottom: 24rpx;
  color: #1a1a2e;
}

.form-actions {
  display: flex;
  gap: 24rpx;
}

.form-actions button {
  flex: 1;
}

/* (add-btn-wrap removed, using secondary-btn-wrap instead) */

/* 副成员提示条 */
.secondary-banner {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #e8f4f8, #d4ecf7);
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 20rpx;
}

.secondary-banner-icon {
  font-size: 24px;
  margin-right: 16rpx;
}

.secondary-banner-text {
  font-size: 17px;
  color: #2c3e50;
  font-weight: 500;
}

/* 副成员管理区域 */
.section-divider {
  height: 2rpx;
  background: linear-gradient(90deg, transparent, #d0d0e0, transparent);
  margin: 40rpx 0 30rpx;
}

.section-title-row {
  margin-bottom: 12rpx;
}

.section-title {
  font-size: 22px;
  font-weight: 700;
  color: #1a1a2e;
}

.section-hint {
  font-size: 16px;
  color: #a0a0b8;
  margin-bottom: 20rpx;
}

.secondary-card {
  margin-top: 16rpx;
}

.secondary-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.secondary-info {
  display: flex;
  align-items: center;
}

.secondary-name {
  font-size: 20px;
  font-weight: 600;
  color: #1a1a2e;
  margin-right: 12rpx;
}

.secondary-actions {
  display: flex;
  gap: 18rpx;
}

.secondary-btn-wrap {
  padding: 0 24rpx;
}

.mt-12 {
  margin-top: 12rpx;
}

/* 邀请面板 */
.invite-code-display {
  background: #f5f7fa;
  border-radius: 12rpx;
  padding: 24rpx;
  text-align: center;
  font-size: 18px;
  font-weight: 600;
  color: #4A90D9;
  word-break: break-all;
  margin: 20rpx 0;
}

.invite-tips {
  font-size: 16px;
  color: #a0a0b8;
  text-align: center;
}
