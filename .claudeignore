# 微信开发者工具自动生成的私有配置（含 appid、密钥等敏感信息）
project.private.config.json

# 微信开发者工具缓存目录
.idea/
.vscode/
*.suo
*.user

# 云函数 node_modules（体积大，内容无需审阅）
cloud/*/node_modules/
cloud/*/package-lock.json
cloud/*/yarn.lock

# 小程序编译产物与缓存
miniprogram_npm/
.cache/

# 日志文件
*.log
logs/

# 操作系统临时文件
.DS_Store
Thumbs.db
desktop.ini

# 编辑器备份文件
*.swp
*.swo
*~
*.bak
*.tmp

# 敏感配置（如本地环境变量）
.env
.env.local
.env.*.local
